generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DailyMenu {
  id        String        @id @default(cuid())
  date      DateTime      @default(now())
  flavors   DailyFlavor[]
  note      String?
  published Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model DailyFlavor {
  id          String    @id @default(cuid())
  dailyMenuId String
  dailyMenu   DailyMenu @relation(fields: [dailyMenuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  tags        String[]
  soldOut     Boolean   @default(false)
  sortOrder   Int       @default(0)
}

model Flavor {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  tags        String[]
  image       String?
  active      Boolean  @default(true)
  seasonal    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CateringInquiry {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String?
  eventType  String
  eventDate  DateTime?
  guestCount String
  budget     String?
  flavors    String?
  message    String?
  status     String    @default("new")
  createdAt  DateTime  @default(now())
}

model CakeOrder {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  pickupDate DateTime
  size       String
  flavors    String
  dedication String?
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  alerts    Boolean  @default(true)
  weekly    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
